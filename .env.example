MODEL_API_PROVIDER=dashscope
MODEL_API_PROVIDER_LABEL=阿里云百炼
MODEL_API_PROTOCOL=responses
MODEL_API_KEY=your_dashscope_api_key
MODEL_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_API_MODEL=qwen-plus
MODEL_API_TIMEOUT_SECONDS=90
MODEL_API_REASONING_EFFORT=medium
MODEL_API_HEAVY_REASONING_EFFORT=high
MODEL_API_AGENT_ENABLED=true

MODEL_API_OCR_PROVIDER=dashscope
MODEL_API_OCR_PROVIDER_LABEL=阿里云百炼
MODEL_API_OCR_PROTOCOL=responses
MODEL_API_OCR_KEY=
MODEL_API_OCR_BASE_URL=
MODEL_API_OCR_ENABLED=true
MODEL_API_OCR_MODEL=qwen-vl-max
MODEL_API_OCR_TIMEOUT_SECONDS=180
MODEL_API_OCR_MAX_OUTPUT_TOKENS=4000
MODEL_API_OCR_IMAGE_DETAIL=high
MODEL_API_OCR_PDF_MODE=hybrid
MODEL_API_OCR_PDF_PAGES_PER_REQUEST=1

MODEL_API_REVIEW_PROVIDER=openai
MODEL_API_REVIEW_PROVIDER_LABEL=OpenAI
MODEL_API_REVIEW_PROTOCOL=responses
MODEL_API_REVIEW_KEY=
MODEL_API_REVIEW_BASE_URL=https://api.openai.com/v1
MODEL_API_REVIEW_ENABLED=true
MODEL_API_REVIEW_MODEL=gpt-5.4-mini
MODEL_API_REVIEW_TIMEOUT_SECONDS=60
MODEL_API_REVIEW_MAX_OUTPUT_TOKENS=1200
MODEL_API_REVIEW_BLOCK_ON_HIGH_RISK=true

# Optional aliases for an OpenAI-only review agent.
# OPENAI_REVIEW_API_KEY=
# OPENAI_REVIEW_MODEL=gpt-5.4-mini
# OPENAI_REVIEW_BASE_URL=https://api.openai.com/v1

WORKFLOW_UPLOAD_TEXT_CHAR_LIMIT=0
WORKFLOW_UPLOAD_TABLE_ROW_LIMIT=0
WORKFLOW_UPLOAD_TABLE_COLUMN_LIMIT=0
WORKFLOW_UPLOAD_PDF_PAGE_LIMIT=0
